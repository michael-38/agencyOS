# Cloudflare Pages headers — applies in order, last match wins per header.

# Default: secure + short cache for HTML so updates roll out fast
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cache-Control: public, max-age=300, must-revalidate

# Fonts: hashed filename behavior — safe to cache for a year, immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Favicon: long cache, content is stable
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

# Sitemap / robots: medium cache (Google re-crawls anyway)
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
